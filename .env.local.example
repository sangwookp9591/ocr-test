# 복사해서 .env.local 로 저장하고 실제 값 채우기.  cp .env.local.example .env.local
# start.sh가 자동 로드. git에 올리지 말 것(.env.local).

# Google Document AI (Gemini/Gemma의 GOOGLE_API_KEY와 다른 키)
DOCAI_API_KEY=AIza...
DOCAI_PROJECT=my-gcp-project
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=abc123def456

# AWS Textract (또는 ~/.aws/credentials 사용)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-northeast-2
